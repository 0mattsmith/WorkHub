{
  "name": "workhub",
  "productName": "WorkHub",
  "version": "1.0.0",
  "description": "A single home for all your school & work web apps — like pinned tabs, in their own desktop app. Includes a Smoothwall sign-in tray indicator.",
  "main": "main.js",
  "author": "Big Man",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.workhub.app",
    "productName": "WorkHub",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "build/icons/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icons/icon.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icons/icon.png"
    }
  }
}
