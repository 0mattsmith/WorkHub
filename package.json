{
  "name": "workhub",
  "productName": "WorkHub",
  "version": "1.0.9",
  "description": "A single home for all your school & work web apps — like pinned tabs, in their own desktop app. Includes a Smoothwall sign-in tray indicator.",
  "main": "main.js",
  "author": "Matt Smith",
  "license": "MIT",
  "repository": "github:0mattsmith/workhub",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.workhub.app",
    "productName": "WorkHub",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "build/icons/**/*",
      "CHANGELOG.md"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "0mattsmith",
        "repo": "workhub",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icons/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["universal"] }],
      "icon": "build/icons/icon.png",
      "category": "public.app-category.productivity",
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icons/icon.png",
      "category": "Utility"
    }
  }
}
